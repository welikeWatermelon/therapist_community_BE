{
  "//": "Claude Code local project settings 예시. 실제 활성화는 .claude/settings.local.json에 복사.",
  "//hookSchema": "hooks.<EventName>는 배열. 각 항목은 matcher / hooks 배열. 자세한 schema는 https://code.claude.com/docs/en/hooks 참조.",
  "//cwd": "프로젝트 스크립트는 cwd가 repo root라는 보장이 없으므로 $CLAUDE_PROJECT_DIR 환경 변수로 절대 경로를 만든다 (Claude Code 공식 안내).",
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/docs/ops/templates/claude-hooks/checkpoint-hook.sh\" pre-compact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/docs/ops/templates/claude-hooks/checkpoint-hook.sh\" post-compact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/docs/ops/templates/claude-hooks/checkpoint-hook.sh\" session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/docs/ops/templates/claude-hooks/checkpoint-hook.sh\" stop"
          }
        ]
      }
    ]
  }
}
