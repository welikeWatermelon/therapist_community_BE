<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- 기본 루트 로거 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- 검색 접근 로그 전용 파일 appender -->
    <appender name="SEARCH_ACCESS_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/search-access.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/search-access.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!-- 비동기 래퍼 (I/O 블로킹 방지) -->
    <appender name="SEARCH_ACCESS" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="SEARCH_ACCESS_FILE"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
    </appender>

    <!-- 검색 접근 로거 (일반 로그와 분리) -->
    <logger name="SEARCH_ACCESS" level="INFO" additivity="false">
        <appender-ref ref="SEARCH_ACCESS"/>
    </logger>
</configuration>
