# === PostgreSQL ===
POSTGRES_DB=builders
POSTGRES_USER=builders
POSTGRES_PASSWORD=builders
POSTGRES_PORT=55432

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === Spring ===
SPRING_PROFILES_ACTIVE=local
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:55432/builders
SPRING_DATASOURCE_USERNAME=builders
SPRING_DATASOURCE_PASSWORD=builders
SERVER_PORT=8080

# === JWT ===
JWT_ACCESS_SECRET=local-dev-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=local-dev-refresh-secret-min-32-chars!
JWT_ACCESS_TTL_SEC=1800
JWT_REFRESH_TTL_SEC=1209600

# === CORS ===
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# === AWS (disabled in local dev) ===
APP_AWS_ENABLED=false
APP_AWS_REGION=ap-northeast-2
APP_AWS_S3_BUCKET=local-test-bucket
